##############
# UI
##############
font-family = Hackgen Console NF
font-size = 13
background = 1D1F24
background-blur = macos-glass-clear
# background-opacity = 0.8
macos-titlebar-style = transparent
# macos-titlebar-proxy-icon = hidden
# a single space forces a blank title; an empty value falls back to the 👻 default
title = " "
macos-window-buttons = hidden

##############
# Action
##############
cursor-style-blink = false
mouse-hide-while-typing = true
quit-after-last-window-closed = true
command = ~/.local/bin/herdr
auto-update = check
macos-dock-drop-behavior = new-window

##############
# Keybinds
##############
keybind = clear

# Workarounds
macos-option-as-alt = true
# https://github.com/ghostty-org/ghostty/discussions/5071
keybind = ctrl+[=esc:
# clipboard
keybind = super+c=copy_to_clipboard:mixed
keybind = super+v=paste_from_clipboard
# font size
keybind = super+==increase_font_size:1
keybind = super+-=decrease_font_size:1
keybind = super+0=reset_font_size
# view
keybind = super+enter=toggle_fullscreen
# reload config after editing this file
keybind = super+shift+,=reload_config
